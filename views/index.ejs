    window.addEventListener(
      "focus",
      function(e) {
        var el = e.target;
        var rectStr = vino.navi_getRect();
        if (!el || !rectStr) return;

        // Parse rect from Wii U API
        var parts = rectStr.split(",");
        if (parts.length < 4) return;

        var naviRect = {
          left: parseInt(parts[0], 10),
          top: parseInt(parts[1], 10),
          width: parseInt(parts[2], 10),
          height: parseInt(parts[3], 10)
        };
        naviRect.right = naviRect.left + naviRect.width;
        naviRect.bottom = naviRect.top + naviRect.height;

        // Viewport bounds
        var viewTop = 0;
        var viewLeft = 0;
        var viewRight = window.innerWidth;
        var viewBottom = window.innerHeight;

        var scrollX = 0;
        var scrollY = 0;

        // --- Vertical scrolling ---
        if (naviRect.top < viewTop) {
          // Align top
          scrollY = naviRect.top - viewTop;
        } else if (naviRect.bottom > viewBottom) {
          if (naviRect.height > window.innerHeight) {
            scrollY = naviRect.top - viewTop;
          } else {
            scrollY = naviRect.bottom - viewBottom;
          }
        }

        // --- Horizontal scrolling ---
        if (naviRect.left < viewLeft) {
          scrollX = naviRect.left - viewLeft;
        } else if (naviRect.right > viewRight) {
          if (naviRect.width > window.innerWidth) {
            scrollX = naviRect.left - viewLeft;
          } else {
            scrollX = naviRect.right - viewRight;
          }
        }

        if (scrollX !== 0 || scrollY !== 0) {
          window.scrollBy(scrollX, scrollY);
        }
      },
      true
    );


    var maxSpeed = 40;
    var deadZone = 0.05;

    var inputCheck = setInterval(function() {
      wiiu.gamepad.update();

      var dx = wiiu.gamepad.lStickX;
      var dy = wiiu.gamepad.lStickY;

      if ((dx !== 0 && dy !== 0) || wiiu.gamepad.tpTouch === 1) {
        vino.navi_reset();
      }

      var movedX = Math.abs(dx) > deadZone;
      var movedY = Math.abs(dy) > deadZone;

      if (!movedX && !movedY) return;

      var sx = movedX ? dx * maxSpeed : 0;
      var sy = movedY ? -dy * maxSpeed : 0; // invert Y

      window.scrollBy(sx, sy);
    }, 16);


