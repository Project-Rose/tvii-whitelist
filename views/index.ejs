    // --- State ---
    var blinkInterval = null;
    var inSpecialState = false;

    // --- Blink loop function ---
    function startBlink(mainImg, blinkImg) {
      if (blinkInterval) {
        clearInterval(blinkInterval);
      }

      attImg.src = mainImg.src;

      blinkInterval = setInterval(function() {
        attImg.src = blinkImg.src;

        setTimeout(function() {
          attImg.src = mainImg.src;
        }, 400);
      }, 3000);
    }

    startBlink(imgNormal, imgBlink);

    setTimeout(function() {
      inSpecialState = true;
      startBlink(imgAltMain, imgAltBlink);
    }, 120 * 1000);

    attImg.onclick = function() {
      if (!inSpecialState) return;

      inSpecialState = false;

      if (blinkInterval) {
        clearInterval(blinkInterval);
        blinkInterval = null;
      }

      attImg.src = imgTouch.src;

      setTimeout(function() {
        startBlink(imgNormal, imgBlink);
      }, 3000);
    };
